<script>
/* ── タブ切替 ── */
function switchTab(id, btn) {
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  btn.classList.add('active');

  document.querySelectorAll('.ranking-panel').forEach(p => p.classList.remove('active'));
  document.getElementById('panel-' + id).classList.add('active');

  /* パネル切り替え時にフェードインを再トリガー */
  document.querySelectorAll('#panel-' + id + ' .fi').forEach(el => {
    el.classList.remove('v');
    obs.observe(el);
  });
}

/* ── フェードイン ── */
const obs = new IntersectionObserver(entries => {
  entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('v'); obs.unobserve(e.target); } });
}, { threshold: .06, rootMargin: '0px 0px -16px 0px' });
document.querySelectorAll('.fi').forEach(el => obs.observe(el));

/* ── スマホ：カード全体タップで遷移 ── */
document.querySelectorAll('.rank-item').forEach(item => {
  item.addEventListener('click', function(e) {
    if (e.target.closest('a') && e.target.closest('a') !== this) return;
    const href = this.getAttribute('href');
    if (href) window.location.href = href;
  });
});

/* ── ハンバーガー ── */
document.querySelectorAll('.mnav a').forEach(a => {
  a.addEventListener('click', () => document.getElementById('mn').classList.remove('open'));
});
</script>

