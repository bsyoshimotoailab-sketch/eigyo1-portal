<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>資料館｜営業-1グランプリ 公式アーカイブ</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700;900&family=Zen+Kaku+Gothic+New:wght@700;900&display=swap" rel="stylesheet">
<style>
/* ── 変数・リセット ── */
:root{
  --white:#fff;--bg:#faf9f6;--bg-warm:#f5f2ec;
  --text:#222;--text-sub:#555;--text-light:#888;
  --gold:#b8922e;--gold-light:#f0d77b;--gold-dark:#8a6d1a;
  --red:#d72631;--red-dark:#b51d26;--black:#1a1a1a;
  --border:#e8e4dc;--shadow:rgba(0,0,0,.08);
  --font:'Noto Sans JP',sans-serif;--font-a:'Zen Kaku Gothic New',sans-serif;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--text);font-family:var(--font);line-height:1.8;overflow-x:hidden;-webkit-font-smoothing:antialiased}
img{max-width:100%;display:block}
a{color:inherit;text-decoration:none}

/* ── ヘッダー ── */
header{position:fixed;top:0;left:0;right:0;z-index:1000;background:rgba(255,255,255,.93);backdrop-filter:blur(14px);border-bottom:1px solid var(--border)}
.h-inner{max-width:1180px;margin:0 auto;padding:0 clamp(16px,4vw,40px);display:flex;align-items:center;justify-content:space-between;height:68px}
.logo{display:flex;align-items:center}
.logo img{height:52px;width:auto;object-fit:contain}
nav{display:flex;align-items:center;gap:16px}
nav a{color:var(--text-sub);font-size:.74rem;font-weight:700;transition:color .3s}
nav a:hover{color:var(--red)}
.ncta{background:var(--red);color:#fff!important;padding:8px 18px;font-weight:700!important;font-size:.72rem!important;border-radius:4px;transition:background .3s!important}
.ncta:hover{background:var(--red-dark)!important}
.hbr{display:none;background:none;border:none;cursor:pointer;padding:6px}
.hbr span{display:block;width:22px;height:2px;background:var(--text);margin:5px 0}
.mnav{display:none;position:fixed;top:68px;left:0;right:0;z-index:999;background:rgba(255,255,255,.97);backdrop-filter:blur(14px);padding:16px 24px;border-bottom:1px solid var(--border)}
.mnav.open{display:block}
.mnav a{display:block;padding:12px 0;color:var(--text-sub);font-size:.85rem;border-bottom:1px solid #eee}

/* ── パンくず ── */
.breadcrumb{background:var(--white);border-bottom:1px solid var(--border);padding:10px 0}
.bc-inner{max-width:1180px;margin:0 auto;padding:0 clamp(16px,4vw,40px);display:flex;align-items:center;gap:8px;flex-wrap:wrap}
.bc-inner a,.bc-inner span{font-size:.72rem;color:var(--text-light)}
.bc-inner a:hover{color:var(--red)}
.bc-sep{color:#ccc}
.bc-inner .current{color:var(--text-sub);font-weight:700}

/* ── ページヒーロー ── */
.page-hero{background:var(--black);padding:clamp(36px,6vw,64px) 0 clamp(28px,5vw,48px)}
.page-hero-inner{max-width:1180px;margin:0 auto;padding:0 clamp(16px,4vw,40px)}
.page-hero-label{font-size:.64rem;letter-spacing:.24em;color:var(--gold-light);font-weight:700;margin-bottom:12px}
.page-hero-title{font-family:var(--font-a);font-size:clamp(1.6rem,4vw,2.6rem);font-weight:900;color:var(--white);line-height:1.25;margin-bottom:12px}
.page-hero-desc{font-size:.88rem;color:#999;max-width:600px;line-height:1.85}

/* ── メイン ── */
.page-wrap{padding-top:68px}
.main-area{max-width:1180px;margin:0 auto;padding:clamp(36px,5vw,56px) clamp(16px,4vw,40px) clamp(60px,10vw,100px)}

/* ── セクション見出し ── */
.sec-head{display:flex;align-items:baseline;gap:14px;margin-bottom:28px;padding-bottom:14px;border-bottom:2px solid var(--border)}
.sec-label{font-family:var(--font-a);font-size:1.6rem;font-weight:900;color:var(--black)}
.sec-sub{font-size:.8rem;color:var(--text-sub)}
.sec-count{font-size:.72rem;color:var(--text-light);margin-left:auto;font-weight:700}

/* ── card-grid ── */
.card-grid{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:20px;
}

/* ── article.card ── */
article.card{
  background:var(--white);
  border:1px solid var(--border);
  border-radius:12px;
  overflow:hidden;
  display:flex;
  flex-direction:column;
  transition:box-shadow .3s,transform .3s;
}
article.card:hover{
  box-shadow:0 10px 36px rgba(0,0,0,.13);
  transform:translateY(-4px);
}

/* サムネイル */
.card-thumb{
  position:relative;
  aspect-ratio:4/3;
  background:#ece9e2;
  overflow:hidden;
}
.card-thumb img{
  width:100%;
  height:100%;
  object-fit:cover;
  transition:transform .4s;
}
article.card:hover .card-thumb img{transform:scale(1.04)}

/* 画像なし時フォールバック */
.card-fallback{
  position:absolute;inset:0;
  display:none;flex-direction:column;
  align-items:center;justify-content:center;
  gap:6px;color:var(--text-light);font-size:.72rem;
}
.card-fallback .ico{font-size:2rem;opacity:.2}

/* カード本文 */
.card-body{
  padding:14px 16px 16px;
  display:flex;flex-direction:column;
  gap:10px;flex:1;
}
.card-title{
  font-size:.92rem;font-weight:700;
  color:var(--black);line-height:1.5;
}
.card-desc{
  font-size:.78rem;color:var(--text-sub);line-height:1.75;
}
.card-btn{
  display:inline-flex;align-items:center;justify-content:center;gap:6px;
  background:var(--red);color:#fff;
  padding:9px 16px;
  border-radius:5px;
  font-size:.76rem;font-weight:700;
  transition:background .25s;
  margin-top:auto;
}
.card-btn:hover{background:var(--red-dark)}

/* ── 下部導線 ── */
.bottom-nav{max-width:1180px;margin:0 auto;padding:0 clamp(16px,4vw,40px) clamp(60px,10vw,90px);display:flex;gap:12px;flex-wrap:wrap;justify-content:center}
.bottom-link{display:inline-flex;align-items:center;gap:8px;padding:12px 24px;border-radius:6px;font-size:.8rem;font-weight:700;border:1.5px solid var(--border);color:var(--text-sub);background:var(--white);transition:all .25s}
.bottom-link:hover{border-color:var(--text);color:var(--black)}

/* ── フッター ── */
footer{background:var(--black);color:#888;padding:32px 0}
.ft-inner{max-width:1180px;margin:0 auto;padding:0 clamp(16px,4vw,40px);display:flex;justify-content:space-between;flex-wrap:wrap;gap:12px;align-items:center}
footer p{font-size:.68rem}
footer a{color:#888;transition:color .3s}
footer a:hover{color:var(--gold-light)}

/* ── フェードイン ── */
.fi{opacity:0;transform:translateY(16px);transition:opacity .5s,transform .5s}
.fi.v{opacity:1;transform:translateY(0)}

/* ── レスポンシブ ── */
@media(max-width:1100px){
  .card-grid{grid-template-columns:repeat(3,1fr)}
}
@media(max-width:960px){
  nav a:not(.ncta){display:none}
  .hbr{display:block}
  .card-grid{grid-template-columns:repeat(2,1fr)}
}
@media(max-width:540px){
  .card-grid{grid-template-columns:1fr}
}
</style>
</head>
<body>

<!-- ヘッダー -->
<header>
  <div class="h-inner">
    <a href="index.html" class="logo">
      <img src="assets/logos/eigyo1_logo.png" alt="営業-1グランプリ ロゴ" onerror="this.style.display='none'">
    </a>
    <nav>
      <a href="index.html#lv">最新情報</a>
      <a href="index.html#about">営業-１グランプリとは？</a>
      <a href="index.html#video">番組動画</a>
      <a href="goods.html">番組関連グッズ</a>
      <a href="timeline.html">シリーズ年表</a>
      <a href="https://www.yoshimoto.co.jp/kogyo-eigyo/" target="_blank" rel="noopener" class="ncta">イベント出演依頼</a>
      <button class="hbr" onclick="document.getElementById('mn').classList.toggle('open')" aria-label="メニュー">
        <span></span><span></span><span></span>
      </button>
    </nav>
  </div>
</header>
<div class="mnav" id="mn">
  <a href="index.html">TOP</a>
  <a href="index.html#about">営業-１グランプリとは？</a>
  <a href="index.html#video">番組動画</a>
  <a href="goods.html">番組関連グッズ</a>
  <a href="timeline.html">シリーズ年表</a>
  <a href="https://www.yoshimoto.co.jp/kogyo-eigyo/" target="_blank" rel="noopener">イベント出演依頼</a>
</div>

<div class="page-wrap">

  <!-- パンくず -->
  <div class="breadcrumb">
    <div class="bc-inner">
      <a href="index.html">TOP</a>
      <span class="bc-sep">›</span>
      <span class="current">資料館</span>
    </div>
  </div>

  <!-- ページヒーロー -->
  <div class="page-hero">
    <div class="page-hero-inner">
      <div class="page-hero-label">DOCUMENT ARCHIVE</div>
      <h1 class="page-hero-title">資料館</h1>
      <p class="page-hero-desc">営業-1グランプリの歴史を記録した貴重な資料をアーカイブしています。台本・企画書・営業資料・過去イベント資料など、番組制作の舞台裏を支えた文書類を公開しています。</p>
    </div>
  </div>

  <!-- メインエリア -->
  <div class="main-area">

    <div class="sec-head fi">
      <span class="sec-label">番組資料アーカイブ</span>
      <span class="sec-sub">台本・企画書・営業資料・イベント資料</span>
      <span class="sec-count">全6件</span>
    </div>

    <div class="card-grid">

      <!-- 01: shiryoukan005 — 台本資料 -->
      <article class="card fi">
        <div class="card-thumb">
          <img src="images/archive/shiryoukan005.jpg" alt="台本資料"
               onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
          <div class="card-fallback"><span class="ico">📄</span><span>画像準備中</span></div>
        </div>
        <div class="card-body">
          <div class="card-title">収録台本資料</div>
          <p class="card-desc">放送回ごとに作成された収録台本の保存版。進行表・ト書き・MC台詞など一式を収録。</p>
          <span class="card-btn">資料を見る</span>
        </div>
      </article>

      <!-- 02: shiryoukan012 — 企画書 -->
      <article class="card fi">
        <div class="card-thumb">
          <img src="images/archive/shiryoukan012.jpg" alt="企画書アーカイブ"
               onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
          <div class="card-fallback"><span class="ico">📄</span><span>画像準備中</span></div>
        </div>
        <div class="card-body">
          <div class="card-title">企画書アーカイブ</div>
          <p class="card-desc">番組立ち上げ当初から蓄積されてきた企画書類。コーナー案・構成メモ・会議資料を含む。</p>
          <span class="card-btn">資料を見る</span>
        </div>
      </article>

      <!-- 03: shiryoukan020 — 営業資料 -->
      <article class="card fi">
        <div class="card-thumb">
          <img src="images/archive/shiryoukan020.jpg" alt="営業資料"
               onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
          <div class="card-fallback"><span class="ico">📄</span><span>画像準備中</span></div>
        </div>
        <div class="card-body">
          <div class="card-title">営業現場資料</div>
          <p class="card-desc">出演者が実際に使用した営業ツール・提案書・セールストーク集のアーカイブ。</p>
          <span class="card-btn">資料を見る</span>
        </div>
      </article>

      <!-- 04: shiryoukan025 — 過去イベント資料 -->
      <article class="card fi">
        <div class="card-thumb">
          <img src="images/archive/shiryoukan025.jpg" alt="過去イベント資料"
               onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
          <div class="card-fallback"><span class="ico">📄</span><span>画像準備中</span></div>
        </div>
        <div class="card-body">
          <div class="card-title">過去イベント資料</div>
          <p class="card-desc">グランプリ授賞式・公開収録・営業イベントの実施報告書・当日プログラム一覧。</p>
          <span class="card-btn">資料を見る</span>
        </div>
      </article>

      <!-- 05: shiryoukan030 — 審査基準資料 -->
      <article class="card fi">
        <div class="card-thumb">
          <img src="images/archive/shiryoukan030.jpg" alt="審査基準資料"
               onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
          <div class="card-fallback"><span class="ico">📄</span><span>画像準備中</span></div>
        </div>
        <div class="card-body">
          <div class="card-title">審査基準・採点資料</div>
          <p class="card-desc">歴代グランプリの採点シートと審査基準書。何が評価されたかを知る公式ドキュメント。</p>
          <span class="card-btn">資料を見る</span>
        </div>
      </article>

      <!-- 06: shiryoukan036 — 出演者プロフィール資料 -->
      <article class="card fi">
        <div class="card-thumb">
          <img src="images/archive/shiryoukan036.jpg" alt="出演者プロフィール資料"
               onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
          <div class="card-fallback"><span class="ico">📄</span><span>画像準備中</span></div>
        </div>
        <div class="card-body">
          <div class="card-title">出演者プロフィール資料</div>
          <p class="card-desc">各シーズンの出演者・スタッフのプロフィールシート。番組制作の記録として保存。</p>
          <span class="card-btn">詳細を見る</span>
        </div>
      </article>

    </div><!-- /card-grid -->

  </div><!-- /main-area -->

  <!-- 下部導線 -->
  <div class="bottom-nav">
    <a href="photo-gallery.html" class="bottom-link">写真館</a>
    <a href="episodes.html" class="bottom-link">エピソード一覧</a>
    <a href="index.html" class="bottom-link">TOPへ戻る</a>
  </div>

</div><!-- /page-wrap -->

<footer>
  <div class="ft-inner">
    <p>© 営業-1グランプリ 公式アーカイブ｜BSよしもと</p>
    <div style="display:flex;gap:20px">
      <a href="index.html">TOP</a>
      <a href="episodes.html">エピソード一覧</a>
      <a href="timeline.html">シリーズ年表</a>
    </div>
  </div>
</footer>

<script>
/* ── フェードイン ── */
const obs = new IntersectionObserver(entries => {
  entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('v'); obs.unobserve(e.target); } });
}, { threshold: .04, rootMargin: '0px 0px -8px 0px' });
document.querySelectorAll('.fi').forEach(el => obs.observe(el));

/* ── ハンバーガー ── */
document.querySelectorAll('.mnav a').forEach(a => {
  a.addEventListener('click', () => document.getElementById('mn').classList.remove('open'));
});
</script>

</body>
</html>
